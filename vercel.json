{
    "version": 2,
    "buildCommand": null,
    "outputDirectory": null,
    "framework": null,
    "functions": {
        "api/remove.py": {
            "runtime": "python3.9",
            "maxDuration": 60,
            "memory": 1024
        }
    },
    "routes": [
        {
            "src": "/api/remove",
            "dest": "/api/remove.py"
        },
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ]
}